async function pushUpdate() {
    const token = localStorage.getItem('iky_token');
    if(!token) return alert("Maaf Tuan, Token GitHub belum diisi!");

    // Ambil data dari form
    const body = {
        name: document.getElementById('db-name').value,
        bio: document.getElementById('db-bio').value,
        projects: [] // Sementara kosongkan atau biarkan sesuai struktur data.json Tuan
    };

    // Tampilkan status loading pada tombol
    const btn = document.querySelector('.btn[onclick="pushUpdate()"]');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> CONNECTING TO GITHUB...';
    btn.disabled = true;

    try {
        // LANGKAH 1: Ambil SHA terbaru dari GitHub (Penting!)
        const getRes = await fetch(`https://api.github.com/repos/${REPO}/contents/data.json`, {
            headers: { 'Authorization': `token ${token}` }
        });
        
        if(!getRes.ok) throw new Error("Gagal mengambil metadata file.");
        const currentData = await getRes.json();
        const latestSha = currentData.sha;

        // LANGKAH 2: Kirim Update dengan SHA terbaru
        const res = await fetch(`https://api.github.com/repos/${REPO}/contents/data.json`, {
            method: 'PUT',
            headers: { 
                'Authorization': `token ${token}`,
                'Content-Type': 'application/json' 
            },
            body: JSON.stringify({
                message: "Update Core v9 - Master Control",
                content: btoa(unescape(encodeURIComponent(JSON.stringify(body, null, 2)))),
                sha: latestSha 
            })
        });

        if(res.ok) {
            alert("✅ PUSH SUCCESS, TUAN IKY!");
            location.reload(); // Refresh untuk sinkronisasi ulang
        } else {
            const errData = await res.json();
            alert("❌ GAGAL PUSH: " + errData.message);
        }
    } catch (err) {
        alert("⚠️ ERROR SISTEM: " + err.message);
    } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
}
